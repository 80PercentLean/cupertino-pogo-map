{
  "name": "cupertino-pogo-map",
  "private": true,
  "version": "0.1.1",
  "author": "80PercentLean",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "npm run build:cup-pogo",
    "build:all": "npm run build:cup-pogo && npm run build:wg",
    "build:all:e2e": "VITE_E2E=true VITE_API=http://localhost:9001/api/v1 npm run build:all",
    "build:cup-pogo": "VITE_IS_CENTRAL=false vite build --outDir dist-cup-pogo",
    "build:cup-pogo:e2e": "VITE_E2E=true VITE_API=http://localhost:9001/api/v1 npm run build:cup-pogo",
    "build:wg": "VITE_IS_CENTRAL=true vite build --outDir dist-wg",
    "build:wg:e2e": "VITE_E2E=true VITE_API=http://localhost:9001/api/v1 npm run build:wg",
    "dev": "vite",
    "dev:cup-pogo:e2e": "nodemon --exec \"npm run build:cup-pogo:e2e && npm run preview:cup-pogo\"",
    "dev:wg:e2e": "nodemon --exec \"npm run build:wg:e2e && npm run preview:wg\"",
    "deploy": "npm run deploy:cup-pogo",
    "deploy:cup-pogo": "npm run typecheck && npm run build:cup-pogo && wrangler deploy --config wrangler.cup-pogo.jsonc",
    "deploy:wg": "npm run typecheck && npm run build:wg && wrangler deploy --config wrangler.wg.jsonc",
    "format": "npm run format:check",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "preview": "npm run preview:cup-pogo",
    "preview:cup-pogo": "wrangler dev --config wrangler.cup-pogo.jsonc --port 8787",
    "preview:wg": "wrangler dev --config wrangler.wg.jsonc --port 8788",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:dev": "npm run test -- --ui",
    "test:e2e": "playwright test",
    "test:e2e:dev": "npm run test:e2e -- --ui",
    "test:e2e:report": "playwright show-report",
    "test:watch": "npm run test watch",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.100.10",
    "@types/lodash-es": "^4.17.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "leaflet-ant-path": "^1.3.0",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.66.1",
    "react-leaflet": "^5.0.0-rc.2",
    "react-router": "^7.9.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.2",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.60.0",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.5",
    "@vitest/ui": "^4.0.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.31",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-dom": "^5.8.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-react-x": "^5.8.3",
    "globals": "^16.4.0",
    "jsdom": "^27.0.1",
    "msw": "^2.14.6",
    "nodemon": "^3.1.14",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.1.7",
    "vite-plugin-stylelint": "^6.0.2",
    "vitest": "^4.0.4",
    "wrangler": "^4.93.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
